# BusyBox configuration for Graphene Node OS
# Minimal utilities - NO SHELLS

CONFIG_BUSYBOX=y

# Build options
CONFIG_STATIC=n
CONFIG_FEATURE_BUFFERS_USE_MALLOC=y
CONFIG_SHOW_USAGE=n
CONFIG_LONG_OPTS=y
CONFIG_FEATURE_VERBOSE_USAGE=n
CONFIG_FEATURE_COMPRESS_USAGE=n
CONFIG_LFS=y

# NO SHELLS - This is critical for security
CONFIG_FEATURE_SH_IS_NONE=y
CONFIG_ASH=n
CONFIG_HUSH=n
CONFIG_SH_IS_NONE=y
CONFIG_BASH_IS_NONE=y
CONFIG_SHELL_ASH=n
CONFIG_SHELL_HUSH=n
CONFIG_FEATURE_SH_STANDALONE=n
CONFIG_FEATURE_SH_NOFORK=n

# No scripting
CONFIG_AWK=n
CONFIG_SED=n

# Init system (minimal)
CONFIG_INIT=y
CONFIG_FEATURE_USE_INITTAB=y
CONFIG_FEATURE_INIT_SCTTY=n
CONFIG_FEATURE_INIT_SYSLOG=n
CONFIG_FEATURE_INIT_QUIET=y
CONFIG_FEATURE_INIT_COREDUMPS=n

# Essential system utilities
CONFIG_MOUNT=y
CONFIG_UMOUNT=y
CONFIG_FEATURE_MOUNT_LOOP=y
CONFIG_FEATURE_MOUNT_VERBOSE=n
CONFIG_MKDIR=y
CONFIG_MKNOD=y
CONFIG_CHMOD=y
CONFIG_CHOWN=y
CONFIG_LN=y
CONFIG_CP=y
CONFIG_MV=y
CONFIG_RM=y

# Process control
CONFIG_KILL=y
CONFIG_KILLALL=y
CONFIG_START_STOP_DAEMON=y
CONFIG_FEATURE_START_STOP_DAEMON_LONG_OPTIONS=y

# File utilities (minimal)
CONFIG_CAT=y
CONFIG_LS=y
CONFIG_FEATURE_LS_SORTFILES=n
CONFIG_FEATURE_LS_TIMESTAMPS=y
CONFIG_HEAD=n
CONFIG_TAIL=n
CONFIG_ECHO=y
CONFIG_PRINTF=n

# Networking (minimal)
CONFIG_IFCONFIG=y
CONFIG_ROUTE=y
CONFIG_IP=y
CONFIG_FEATURE_IP_ADDRESS=y
CONFIG_FEATURE_IP_LINK=y
CONFIG_FEATURE_IP_ROUTE=y
CONFIG_HOSTNAME=y

# System information
CONFIG_DMESG=y
CONFIG_FEATURE_DMESG_PRETTY=n
CONFIG_PS=y
CONFIG_FEATURE_PS_WIDE=n
CONFIG_FREE=y
CONFIG_UPTIME=y

# Syslog (for logging)
CONFIG_SYSLOGD=y
CONFIG_FEATURE_SYSLOGD_DUP=n
CONFIG_FEATURE_SYSLOGD_CFG=n
CONFIG_FEATURE_SYSLOGD_READ_BUFFER_SIZE=256
CONFIG_KLOGD=y

# Kernel modules
CONFIG_MODPROBE=y
CONFIG_INSMOD=y
CONFIG_RMMOD=y
CONFIG_LSMOD=y
CONFIG_FEATURE_MODPROBE_SMALL=y

# Date/time
CONFIG_DATE=y

# Sleep (for init scripts)
CONFIG_SLEEP=y
CONFIG_USLEEP=y

# Disable interactive/dangerous utilities
CONFIG_GETTY=n
CONFIG_LOGIN=n
CONFIG_SULOGIN=n
CONFIG_PASSWD=n
CONFIG_SU=n
CONFIG_ADDUSER=n
CONFIG_DELUSER=n
CONFIG_ADDGROUP=n
CONFIG_DELGROUP=n
CONFIG_CHPASSWD=n
CONFIG_CRYPTPW=n
CONFIG_MKPASSWD=n
CONFIG_HTTPD=n
CONFIG_TELNETD=n
CONFIG_FTPD=n
CONFIG_TFTPD=n

# Disable editors
CONFIG_VI=n
CONFIG_ED=n

# Disable file transfer
CONFIG_WGET=n
CONFIG_FTPGET=n
CONFIG_FTPPUT=n
CONFIG_TFTP=n

# Disable compression utilities
CONFIG_GZIP=n
CONFIG_GUNZIP=n
CONFIG_BZIP2=n
CONFIG_BUNZIP2=n
CONFIG_TAR=n
CONFIG_UNZIP=n
CONFIG_XZ=n
