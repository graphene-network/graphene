#!/bin/busybox
# Graphene Node startup script
# Runs graphene-node as the primary service

NAME="graphene-node"
DAEMON="/usr/bin/graphene-node"
CONFIG="/etc/graphene/node-config.toml"
LOGFILE="/var/log/graphene/node.log"

start() {
    printf "Starting %s: " "$NAME"

    # Ensure log directory exists
    mkdir -p /var/log/graphene
    mkdir -p /var/lib/graphene
    mkdir -p /var/lib/firecracker

    # Check for config file
    if [ ! -f "$CONFIG" ]; then
        echo "WARN: No config file at $CONFIG, using defaults"
    fi

    # Start graphene-node in background
    # The node will output bootstrap info on first run
    start-stop-daemon -S -b -m -p /var/run/graphene.pid \
        -x "$DAEMON" -- \
        --config "$CONFIG" \
        >> "$LOGFILE" 2>&1

    if [ $? -eq 0 ]; then
        echo "OK"
    else
        echo "FAIL"
        return 1
    fi
}

stop() {
    printf "Stopping %s: " "$NAME"
    start-stop-daemon -K -p /var/run/graphene.pid
    if [ $? -eq 0 ]; then
        echo "OK"
    else
        echo "FAIL"
        return 1
    fi
}

restart() {
    stop
    sleep 1
    start
}

status() {
    if [ -f /var/run/graphene.pid ]; then
        PID=$(cat /var/run/graphene.pid)
        if [ -d "/proc/$PID" ]; then
            echo "$NAME is running (PID $PID)"
            return 0
        fi
    fi
    echo "$NAME is not running"
    return 1
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        restart
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
esac
