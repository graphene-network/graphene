# Minimal Linux kernel config for Graphene Node OS
# Optimized for running as a host OS for Firecracker VMs

# General setup
CONFIG_LOCALVERSION="-graphene"
CONFIG_DEFAULT_HOSTNAME="graphene-node"
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_PREEMPT_VOLUNTARY=y
CONFIG_IKCONFIG=n
CONFIG_LOG_BUF_SHIFT=14
CONFIG_CGROUPS=y
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# Processor type
CONFIG_SMP=y
CONFIG_NR_CPUS=64
CONFIG_X86_LOCAL_APIC=y
CONFIG_X86_IO_APIC=y
CONFIG_MCORE2=y

# Power management (minimal)
CONFIG_ACPI=y
CONFIG_ACPI_BUTTON=n
CONFIG_ACPI_FAN=n
CONFIG_ACPI_PROCESSOR=y

# Virtualization - KVM support (for Firecracker)
CONFIG_VIRTUALIZATION=y
CONFIG_KVM=y
CONFIG_KVM_INTEL=y
CONFIG_KVM_AMD=y
CONFIG_VHOST_NET=y

# Networking
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_IP_MULTICAST=y
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y
CONFIG_IP_ROUTE_MULTIPATH=y
CONFIG_NET_IPIP=n
CONFIG_SYN_COOKIES=y
CONFIG_INET_ESP=n
CONFIG_INET_AH=n
CONFIG_IPV6=y
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_NAT=y
CONFIG_BRIDGE=y
CONFIG_VLAN_8021Q=n
CONFIG_NET_SCHED=y
CONFIG_NET_CLS_ACT=y

# TUN/TAP for Firecracker networking
CONFIG_TUN=y

# Device drivers (minimal)
CONFIG_PCI=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_FW_LOADER=n

# Block devices
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_NVME=y
CONFIG_VIRTIO_BLK=y

# SCSI (minimal for virtio)
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI_VIRTIO=y

# Input (minimal - no interactive)
CONFIG_INPUT=y
CONFIG_INPUT_KEYBOARD=n
CONFIG_INPUT_MOUSE=n
CONFIG_SERIO=n
CONFIG_VT=n
CONFIG_VT_CONSOLE=n

# Serial console (for debugging)
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# Virtio
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BALLOON=n
CONFIG_VIRTIO_INPUT=n
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_NET=y

# Network drivers
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y
CONFIG_VIRTIO_NET=y
CONFIG_TUN=y
CONFIG_VETH=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVPTS_FS=y

# dm-verity for root verification
CONFIG_BLK_DEV_DM=y
CONFIG_DM_VERITY=y
CONFIG_DM_VERITY_VERIFY_ROOTHASH_SIG=n

# Security
CONFIG_SECURITY=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_STRICT_KERNEL_RWX=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y

# Crypto (minimal)
CONFIG_CRYPTO=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_AES=y

# Disable debug options
CONFIG_DEBUG_KERNEL=n
CONFIG_PRINTK_TIME=n
CONFIG_DEBUG_FS=n
CONFIG_KALLSYMS=n
CONFIG_KALLSYMS_ALL=n
CONFIG_PROFILING=n
CONFIG_DEBUG_INFO=n

# Module support (minimal)
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=n
