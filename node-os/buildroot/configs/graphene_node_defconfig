# Graphene Node Buildroot Configuration
# Minimal, hardened Linux host OS for running Firecracker and graphene-node

# Target architecture
BR2_x86_64=y
BR2_x86_generic=y

# Build options
BR2_JLEVEL=0
BR2_CCACHE=y
BR2_CCACHE_DIR="$(HOME)/.buildroot-ccache"

# Toolchain - use musl for smaller binaries
BR2_TOOLCHAIN_EXTERNAL=y
BR2_TOOLCHAIN_EXTERNAL_CUSTOM=y
BR2_TOOLCHAIN_EXTERNAL_DOWNLOAD=y
BR2_TOOLCHAIN_EXTERNAL_URL="https://musl.cc/x86_64-linux-musl-cross.tgz"
BR2_TOOLCHAIN_EXTERNAL_GCC_13=y
BR2_TOOLCHAIN_EXTERNAL_HEADERS_6_6=y
BR2_TOOLCHAIN_EXTERNAL_CUSTOM_MUSL=y
BR2_TOOLCHAIN_EXTERNAL_CXX=y

# Kernel
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_VERSION=y
BR2_LINUX_KERNEL_CUSTOM_VERSION_VALUE="6.6.70"
BR2_LINUX_KERNEL_USE_CUSTOM_CONFIG=y
BR2_LINUX_KERNEL_CUSTOM_CONFIG_FILE="$(BR2_EXTERNAL_GRAPHENE_PATH)/board/graphene/linux.config"
BR2_LINUX_KERNEL_VMLINUX=y
BR2_LINUX_KERNEL_INSTALL_TARGET=n

# System configuration
BR2_TARGET_GENERIC_HOSTNAME="graphene-node"
BR2_TARGET_GENERIC_ISSUE="Graphene Network Node OS"
BR2_SYSTEM_DHCP=""
BR2_INIT_BUSYBOX=y
BR2_ROOTFS_DEVICE_CREATION_DYNAMIC_DEVTMPFS=y
BR2_SYSTEM_BIN_SH_NONE=y
BR2_SYSTEM_DEFAULT_PATH="/usr/sbin:/usr/bin:/sbin:/bin"

# Filesystem
BR2_TARGET_ROOTFS_EXT2=y
BR2_TARGET_ROOTFS_EXT2_4=y
BR2_TARGET_ROOTFS_EXT2_SIZE="48M"
BR2_TARGET_ROOTFS_EXT2_MKFS_OPTIONS="-O ^metadata_csum"

# Packages - minimal set
BR2_PACKAGE_BUSYBOX=y
BR2_PACKAGE_BUSYBOX_CONFIG="$(BR2_EXTERNAL_GRAPHENE_PATH)/board/graphene/busybox.config"
BR2_PACKAGE_KMOD=y
BR2_PACKAGE_CA_CERTIFICATES=y

# Our custom packages
BR2_PACKAGE_GRAPHENE_NODE=y
BR2_PACKAGE_FIRECRACKER=y

# Security hardening
BR2_PACKAGE_BUSYBOX_SHOW_OTHERS=y
BR2_OPTIMIZE_2=y
BR2_SSP_STRONG=y
BR2_RELRO_FULL=y
BR2_FORTIFY_SOURCE_2=y

# Strip binaries for smaller size
BR2_STRIP_strip=y
BR2_STRIP_EXCLUDE_FILES=""
BR2_STRIP_EXCLUDE_DIRS=""

# Remove documentation and locales
BR2_ENABLE_LOCALE_PURGE=y
BR2_ENABLE_LOCALE_WHITELIST="C"
BR2_GENERATE_LOCALE=""

# Post-build script
BR2_ROOTFS_POST_BUILD_SCRIPT="$(BR2_EXTERNAL_GRAPHENE_PATH)/board/graphene/post-build.sh"
BR2_ROOTFS_POST_SCRIPT_ARGS=""
