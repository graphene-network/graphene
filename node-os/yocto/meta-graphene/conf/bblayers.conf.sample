# Graphene Node OS - bblayers.conf Sample
# SPDX-License-Identifier: Apache-2.0
#
# Copy this to your build/conf/bblayers.conf and customize paths.

POKY_BBLAYERS_CONF_VERSION = "2"

BBPATH = "${TOPDIR}"
BBFILES ?= ""

# Layer paths - adjust YOCTOROOT to your Yocto installation
YOCTOROOT = "/path/to/poky"
GRAPHENEROOT = "/path/to/graphene/node-os/yocto"

BBLAYERS ?= " \
    ${YOCTOROOT}/meta \
    ${YOCTOROOT}/meta-poky \
    ${YOCTOROOT}/meta-yocto-bsp \
    ${GRAPHENEROOT}/meta-graphene \
"
