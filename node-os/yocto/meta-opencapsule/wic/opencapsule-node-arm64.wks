# OpenCapsule Node OS Disk Image Layout (ARM64)
# SPDX-License-Identifier: Apache-2.0

# EFI System Partition
part /boot/efi --source bootimg-efi --sourceparams="loader=grub-efi" \
    --ondisk sda --label msdos --active --align 1024 --size 64M

# Root filesystem
part / --source rootfs --ondisk sda --fstype=ext4 --label root \
    --align 1024 --size 48M

bootloader --ptable gpt --timeout=0 --append="console=ttyAMA0,115200 panic=1 quiet"
