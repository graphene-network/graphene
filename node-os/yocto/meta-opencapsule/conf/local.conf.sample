# OpenCapsule Node OS - local.conf Sample
# SPDX-License-Identifier: Apache-2.0
#
# Copy this to your build/conf/local.conf and customize as needed.

# Machine selection (choose one)
MACHINE = "opencapsule-node-x86_64"
# MACHINE = "opencapsule-node-aarch64"

# Parallelism
BB_NUMBER_THREADS = "${@oe.utils.cpu_count()}"
PARALLEL_MAKE = "-j ${@oe.utils.cpu_count()}"

# Download directory (shared across builds)
DL_DIR ?= "${TOPDIR}/../downloads"

# Shared state cache (critical for fast builds)
SSTATE_DIR ?= "${TOPDIR}/../sstate-cache"

# Build output directory
TMPDIR = "${TOPDIR}/tmp"

# Package format
PACKAGE_CLASSES = "package_rpm"

# License configuration
LICENSE_FLAGS_ACCEPTED = ""

# SDK machine
SDKMACHINE = "x86_64"

# Extra image configuration
EXTRA_IMAGE_FEATURES = ""

# Attestation values (set by CI)
# OPENCAPSULE_VERITY_ROOT = ""
# OPENCAPSULE_PCR_0 = ""
# OPENCAPSULE_PCR_7 = ""

# S3 sstate mirror (read-only, for CI)
# SSTATE_MIRRORS = "file://.* https://s3.amazonaws.com/opencapsule-sstate/PATH"

# Enable SPDX SBOM generation
INHERIT += "create-spdx"
