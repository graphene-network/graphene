{
  "name": "@graphene/sdk",
  "version": "0.1.0",
  "description": "High-level TypeScript client for Graphene Network",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test tests/integration.test.ts tests/client.test.ts",
    "test:watch": "bun test --watch tests/integration.test.ts tests/client.test.ts",
    "test:e2e": "bun test ./tests/*.e2e.test.ts --timeout 120000",
    "test:all": "bun test tests/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@graphene/sdk-native": "workspace:native"
  },
  "devDependencies": {
    "@noble/ed25519": "^2.1.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/graphene-network/graphene"
  },
  "license": "AGPL-3.0-only",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "graphene",
    "unikernel",
    "compute",
    "serverless"
  ]
}
