{
  "name": "monad",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "packages/*",
    "sdks/*"
  ],
  "scripts": {
    "test": "bun run test:sdk",
    "test:anchor": "anchor test",
    "test:sdk": "bun test --cwd sdks/node tests/integration.test.ts tests/client.test.ts",
    "test:sdk:e2e": "bun test --cwd sdks/node ./tests/*.e2e.test.ts --timeout 120000",
    "postinstall": "lefthook install"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.95.0",
    "smol-toml": "^1.6.0"
  },
  "devDependencies": {
    "@coral-xyz/anchor-cli": "^0.31.2",
    "@types/bn.js": "^5.1.0",
    "@types/bun": "^1.3.8",
    "lefthook": "^1.11.13",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.7.3"
  }
}
