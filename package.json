{
  "name": "graphene",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "sdks/*"
  ],
  "scripts": {
    "test": "bun run test:sdk",
    "test:sdk": "bun test --cwd sdks/node tests/integration.test.ts tests/client.test.ts",
    "test:sdk:e2e": "bun test --cwd sdks/node ./tests/*.e2e.test.ts --timeout 120000",
    "postinstall": "lefthook install"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "lefthook": "^1.11.13",
    "typescript": "^5.7.3"
  }
}
